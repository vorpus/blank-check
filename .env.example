# =============================================================================
# Dopamine -- Stage 1 local environment (COMMITTED template).
#
# Copy to .env (gitignored) -- `make up` does this automatically on first run:
#   cp .env.example .env
#
# Stage 1 needs ZERO real external keys. fake-gen replaces Anthropic + the
# image provider; MinIO replaces R2; the postgres/redis containers replace
# Neon/Upstash. The only "credentials" below are throwaway local defaults that
# protect nothing real. A fresh clone works with this file verbatim.
#
# Anything secret (real R2/Neon/Upstash/Anthropic keys) arrives in Stage 05 and
# lives ONLY in .env (gitignored) or a secrets manager -- never here.
# =============================================================================

# ---- Postgres (-> Neon in Stage 05; swap DATABASE_URL) ----------------------
DATABASE_URL=postgresql://app:app@postgres:5432/dopamine?schema=public

# ---- Redis: cache + BullMQ queue + pub/sub + locks (-> Upstash; swap URL) ---
REDIS_URL=redis://redis:6379

# ---- Object storage: MinIO locally (-> Cloudflare R2 + CDN; swap these) -----
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=listing-images
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/listing-images
# MinIO root creds (also feed S3_ACCESS_KEY_ID/SECRET via compose defaults).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---- Generation seam: fake-gen replaces Anthropic + image provider ----------
FAKEGEN_URL=http://fake-gen:8090

# ---- api --------------------------------------------------------------------
PORT=8080
CORS_ORIGIN=http://localhost:3000
# Image ingest safety (H3): per-blob fetch cap before writing to object storage.
MAX_IMAGE_BYTES=5242880
# Exact-cache canon->listingId TTL in seconds (M1).
EXACT_CACHE_TTL_SEC=3600

# ---- web (NEXT_PUBLIC_* is baked for the browser -> host-published api port) -
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# =============================================================================
# Intentionally ABSENT in Stage 1 (do not add real keys to run the demo):
#   ANTHROPIC_API_KEY        -> added in Stage 02 (real generation)
#   IMAGE_PROVIDER_API_KEY   -> added in Stage 02
#   R2 / Neon / Upstash / Ably creds -> added in Stage 05 (managed services)
# =============================================================================
