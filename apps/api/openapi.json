{
  "openapi": "3.1.0",
  "paths": {
    "/v1/identity/device": {
      "post": {
        "operationId": "IdentityController_device_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceIdentityResponseDto"
                }
              }
            }
          }
        },
        "summary": "Bootstrap/resolve an anonymous device identity, issue a bearer token",
        "tags": [
          "identity"
        ]
      }
    },
    "/v1/listings/{id}": {
      "get": {
        "operationId": "CatalogController_getListing_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListingResponseDto"
                }
              }
            }
          }
        },
        "summary": "Get a listing by id (attributes, media, imageUrls, status)",
        "tags": [
          "catalog"
        ]
      }
    },
    "/v1/storefronts/{id}/categories": {
      "get": {
        "operationId": "CatalogController_categories_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "List a storefront's category tree",
        "tags": [
          "catalog"
        ]
      }
    },
    "/v1/search": {
      "get": {
        "operationId": "SearchController_doSearch_v1",
        "parameters": [
          {
            "name": "storefrontId",
            "required": false,
            "in": "query",
            "schema": {}
          },
          {
            "name": "q",
            "required": true,
            "in": "query",
            "schema": {}
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResultDto"
                }
              }
            }
          }
        },
        "summary": "Search the catalog; returns a blended grid + a generation hint on a miss",
        "tags": [
          "search"
        ]
      }
    },
    "/v1/health": {
      "get": {
        "operationId": "HealthController_health_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Liveness/readiness probe (pings Postgres + Redis)",
        "tags": [
          "health"
        ]
      }
    }
