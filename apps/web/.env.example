# Base origin of the api (REST /v1 + SSE). No trailing slash.
# Local dev (web on host, api on host): http://localhost:8080
# In docker-compose the web container reaches the api as http://api:8080, but the
# BROWSER also needs a reachable origin for client-side calls + SSE, so this is
# set to the host-published origin in compose. Stage 1 keeps it simple: one URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
